<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/app_accent_soft" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/app_accent" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/app_surface_alt" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="@color/app_surface_border" />
        </shape>
    </item>
</selector>
