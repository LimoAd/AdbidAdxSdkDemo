<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-sdk tools:overrideLibrary="com.limo.sdk.common,com.bytedance.gromore" />


    <application
        android:name="com.yiman.ad.MyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AdBid"

        tools:replace="android:allowBackup">


        <activity android:name=".ad.SplashActivity" />
        <activity android:name=".ad.BannerActivity" />
        <activity android:name=".ad.InterstitialActivity" />
        <activity android:name=".ad.RewardActivity" />
        <activity
            android:name="com.yiman.ad.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AdBid">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ad.NativeAdActivity" />
        <activity android:name=".ad.NativeAdRecycleActivity" />



    </application>

</manifest>